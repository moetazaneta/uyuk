{
  "name": "uyuk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:backend": "convex dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "convex codegen && tsc --noEmit",
